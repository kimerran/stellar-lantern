{
  "name": "lantern-stellar-wallet",
  "version": "0.1.0",
  "description": "Lantern — a non-custodial Stellar browser-extension wallet (MV3).",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:mobile": "tsc --noEmit && vite build --config vite.config.mobile.ts && node -e \"require('fs').copyFileSync('dist-mobile/index.mobile.html','dist-mobile/index.html')\"",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync android",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.2.1",
    "@capacitor/preferences": "^6.0.4",
    "@noble/hashes": "1.8.0",
    "@stellar/stellar-sdk": "15.1.0",
    "bip39": "3.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@crxjs/vite-plugin": "2.6.1",
    "@types/chrome": "0.0.270",
    "@types/node": "22.10.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.18.0",
    "@typescript-eslint/parser": "8.18.0",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "10.5.0",
    "buffer": "6.0.3",
    "eslint": "8.57.1",
    "eslint-plugin-react-hooks": "4.6.2",
    "postcss": "8.5.15",
    "prettier": "3.4.2",
    "tailwindcss": "3.4.19",
    "typescript": "5.7.2",
    "vite": "6.3.6",
    "vite-plugin-node-polyfills": "0.28.0",
    "vitest": "4.1.8"
  }
}
